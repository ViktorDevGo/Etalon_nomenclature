# Example environment variables for Docker deployment
# Copy this file to .env and fill in your actual values

# ================================
# DATABASE CONFIGURATION
# ================================
# Option 1: Separate variables (RECOMMENDED - automatically handles special characters in password)
DB_HOST=c37e696087932476c61fd621.twc1.net
DB_PORT=5432
DB_USER=gen_user
DB_PASSWORD=your_password_here
DB_NAME=default_db
DB_SSLMODE=require

# Option 2: Full DSN (only use if NOT using DB_* variables above)
# If your password has special characters like < > ; : @ / ? # & = space
# You MUST URL-encode them: < = %3C, > = %3E, ; = %3B, etc.
# DATABASE_DSN=postgresql://gen_user:encoded_password@host:5432/default_db?sslmode=require

# Connection pool settings
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=5m

# ================================
# SSL CERTIFICATE (Base64 Encoded)
# ================================
# To encode your certificate:
# cat ~/.cloud-certs/root.crt | base64 | tr -d '\n'
PGSSLROOTCERT_BASE64=LS0tLS1CRUdJTiBDRVJUSUZJQ0FURS0tLS0t...

# ================================
# EMAIL MAILBOXES (JSON Format)
# ================================
# Format: JSON array of mailbox objects
# Example:
# MAILBOXES_JSON='[{"email":"user1@domain.com","password":"pass1","host":"mail.hosting.reg.ru","port":993},{"email":"user2@domain.com","password":"pass2","host":"mail.hosting.reg.ru","port":993}]'
MAILBOXES_JSON='[{"email":"example@domain.com","password":"yourpassword","host":"mail.hosting.reg.ru","port":993}]'

# ================================
# EMAIL FILTERING
# ================================
# Only process emails from these senders (comma-separated)
# Leave empty to process emails from any sender
# Example: ALLOWED_SENDERS=sender1@domain.com,sender2@domain.com
ALLOWED_SENDERS=pna@sibzapaska.ru,m.timoshenkova@bigm.pro,b2bportal@brinex.ru

# ================================
# APPLICATION SETTINGS
# ================================
# How often to check for new emails (e.g., 1m, 5m, 10s)
POLL_INTERVAL=1m

# Timezone
TZ=Europe/Moscow
